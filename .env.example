# NSS Blood System Environment Variables Template
# Copy this file to .env and configure the variables accordingly.

# Django Security settings
DEBUG=True
SECRET_KEY=django-insecure-change-this-in-production-use-a-secure-random-key
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration (Optional: defaults to SQLite if left empty)
# Example PostgreSQL: postgres://user:password@localhost:5432/dbname
# DATABASE_URL=sqlite:///db.sqlite3
